&share
 wrf_core = 'ARW',
 max_dom = 1,
 start_date = '2024-01-15_00:00:00',
 end_date   = '2024-01-15_00:00:00',
 interval_seconds = 21600,
 io_form_geogrid = 2,
/

&geogrid
 parent_id         = 1,
 parent_grid_ratio = 1,
 i_parent_start    = 1,
 j_parent_start    = 1,
 e_we              = 5,
 e_sn              = 5,
 geog_data_res     = 'default',
 dx = 0.5,
 dy = 0.5,
 map_proj = 'lat-lon',
 ref_lat   = 50.0,
 ref_lon   = 10.0,
 geog_data_path = '/skip-geogrid',
 ! geogrid.exe is not run in this integration test (no static GEOG data needed).
/

&ungrib
 out_format = 'WPS',
 prefix = 'FILE',
/

&metgrid
 fg_name = 'FILE',
 io_form_metgrid = 2,
/
